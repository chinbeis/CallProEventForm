"use client";

import Link from "next/link";
import { useCallback, useEffect, useMemo, useRef, useState } from "react";
import { checkInByCodeAction } from "@/app/actions/attendees";
import { Input } from "@/components/ui/input";
import { Card, CardContent } from "@/components/ui/card";
import { Label } from "@/components/ui/label";
import { ParticleBG } from "@/components/atoms/ParticleBG";
import { StatusOverlay } from "@/components/atoms/statusOverlay";
import { MenuIcons } from "@/components/icons";
import type { DB, EventCheckinProps, Status } from "@/lib/types";

const CODE_LENGTH = 6;

const statStyles = [
  {
    label: "Нийт",
    valueClass: "text-[hsl(216,75%,66%)]",
    shadowClass: "shadow-[0_4px_20px_rgba(102,155,233,0.3)]",
  },
  {
    label: "Ирсэн",
    valueClass: "text-[hsl(145,100%,45%)]",
    shadowClass: "shadow-[0_4px_20px_rgba(0,200,83,0.3)]",
  },
  {
    label: "Хүлээгдэж буй",
    valueClass: "text-[hsl(40,100%,55%)]",
    shadowClass: "shadow-[0_4px_20px_rgba(102,155,233,0.3)]",
  },
] as const;

const recentAnimationDelayClasses = [
  "[animation-delay:0s]",
  "[animation-delay:0.08s]",
  "[animation-delay:0.16s]",
  "[animation-delay:0.24s]",
  "[animation-delay:0.32s]",
] as const;

export default function EventCheckin({ initialDb }: EventCheckinProps) {
  const [db, setDb] = useState<DB>(initialDb);
  const [code, setCode] = useState("");
  const [status, setStatus] = useState<Status>(null);
  const [errMsg, setErrMsg] = useState("");
  const [foundName, setFoundName] = useState("");
  const [isSubmitting, setIsSubmitting] = useState(false);
  const inputRef = useRef<HTMLInputElement>(null);

  useEffect(() => {
    inputRef.current?.focus();
  }, []);

  const clearFeedback = useCallback((nextStatus: Status) => {
    const timeout = nextStatus === "success" ? 3000 : nextStatus === "already" ? 2500 : 2000;

    window.setTimeout(() => {
      setStatus(null);
      setCode("");
      setErrMsg("");
      if (nextStatus === "success") {
        setFoundName("");
      }
      inputRef.current?.focus();
    }, timeout);
  }, []);

  const handleSubmit = useCallback(async () => {
    if (!code.trim() || isSubmitting) return;

    setIsSubmitting(true);
    try {
      const result = await checkInByCodeAction(code.trim());
      setDb(result.db);
      setStatus(result.status);
      setErrMsg(result.errMsg);
      setFoundName(result.foundName);
      clearFeedback(result.status);
    } finally {
      setIsSubmitting(false);
    }
  }, [clearFeedback, code, isSubmitting]);

  const handleKeyDown = useCallback(
    (e: React.KeyboardEvent<HTMLInputElement>) => {
      if (e.key === "Enter") {
        void handleSubmit();
      }
    },
    [handleSubmit]
  );

  const handleCodeChange = useCallback((value: string) => {
    setCode(value.toUpperCase().slice(0, CODE_LENGTH));
  }, []);

  const totalA = db.attendees.length;
  const checkedA = db.attendees.filter((attendee) => attendee.checkedIn).length;
  const recentCheckedIn = useMemo(
    () =>
      [...db.attendees]
        .filter((attendee) => attendee.checkedIn && attendee.checkedInAt)
        .sort((a, b) => (b.checkedInAt ?? "").localeCompare(a.checkedInAt ?? ""))
        .slice(0, 5),
    [db.attendees]
  );

  const stats = [
    { ...statStyles[0], label: "Нийт", val: totalA },
    { ...statStyles[1], label: "Ирсэн", val: checkedA },
    { ...statStyles[2], label: "Хүлээгдэж буй", val: totalA - checkedA },
  ];

  return (
    <div className="relative min-h-screen overflow-hidden bg-[linear-gradient(160deg,hsl(216,100%,11%)_0%,hsl(216,100%,7%)_50%,hsl(220,100%,9%)_100%)] font-GIP">
      <ParticleBG />

      <div className="pointer-events-none fixed right-[-200px] top-[-300px] z-0 h-[700px] w-[700px] rounded-full bg-[radial-gradient(circle,rgba(0,85,216,0.22)_0%,transparent_65%)]" />
      <div className="pointer-events-none fixed bottom-[-200px] left-[-200px] z-0 h-[600px] w-[600px] rounded-full bg-[radial-gradient(circle,rgba(102,155,233,0.14)_0%,transparent_65%)]" />
      <div className="pointer-events-none fixed left-1/2 top-1/2 z-0 h-[400px] w-[900px] -translate-x-1/2 -translate-y-1/2 bg-[radial-gradient(ellipse,rgba(0,85,216,0.08)_0%,transparent_70%)]" />

      <StatusOverlay status={status} foundName={foundName} errMsg={errMsg} />

      <div className="relative z-10 flex min-h-screen flex-col items-center px-5 py-10">
        {/* <div className="mb-8 flex w-full max-w-[520px] items-center justify-end animate-fade-in">
          <Link
            href="/admin"
            className="rounded-xl border border-[rgba(100,160,255,0.2)] bg-[rgba(0,55,160,0.4)] px-4 py-2 text-xs font-semibold text-[hsl(216,75%,72%)] shadow-[0_2px_12px_rgba(0,85,216,0.2)] backdrop-blur-[12px] transition-all hover:scale-105"
          >
            Удирдах
          </Link>
        </div> */}

        <div className="mb-10 text-center animate-slide-down">
          <div className="mb-6 inline-flex h-24 w-24 items-center justify-center rounded-[28px] bg-[linear-gradient(135deg,#0055d8_0%,#669be9_100%)] shadow-[0_0_0_8px_rgba(0,85,216,0.15),0_0_0_20px_rgba(0,85,216,0.07),0_20px_60px_rgba(0,85,216,0.5)]">
            <MenuIcons.Logo className="h-11 w-11" />
          </div>
          <h1 className="font-GIP bg-[linear-gradient(180deg,#ffffff_30%,hsl(216,75%,66%)_100%)] bg-clip-text text-5xl font-extrabold tracking-tight text-transparent">
            CаllPro Entec 2026
          </h1>
          <p className="mt-2 text-sm font-medium text-[hsl(216,75%,55%)]">CallPro</p>
        </div>

        <div className="mb-10 flex gap-3 animate-fade-in [animation-delay:0.2s]">
          {stats.map((stat) => (
            <div
              key={stat.label}
              className={`rounded-2xl border border-[rgba(100,160,255,0.14)] bg-[rgba(0,40,120,0.35)] px-5 py-3 text-center backdrop-blur-[12px] ${stat.shadowClass}`}
            >
              <p className={`text-2xl font-extrabold ${stat.valueClass}`}>{stat.val}</p>
              <p className="mt-0.5 text-[11px] font-medium text-[rgba(150,190,255,0.45)]">{stat.label}</p>
            </div>
          ))}
        </div>

        <Card className="w-full max-w-[480px] overflow-hidden rounded-[28px] border border-[rgba(100,160,255,0.18)] bg-[linear-gradient(180deg,rgba(0,45,140,0.5)_0%,rgba(0,25,90,0.6)_100%)] shadow-[0_40px_100px_rgba(0,0,0,0.5),inset_0_0_0_1px_rgba(255,255,255,0.03),inset_0_1px_0_rgba(150,200,255,0.12)] backdrop-blur-[24px] animate-slide-up [animation-delay:0.3s]">
          <div className="mx-auto h-px w-2/3 bg-[linear-gradient(90deg,transparent,rgba(100,160,255,0.7),transparent)]" />

          <CardContent className="space-y-5 px-8 pb-8 pt-7">
            <Label className="block text-xs font-bold uppercase tracking-[0.2em] text-[hsl(216,75%,65%)]">
              Бүртгэлийн код
            </Label>

            <div className="relative">
              <Input
                ref={inputRef}
                value={code}
                onChange={(e) => handleCodeChange(e.target.value)}
                onKeyDown={handleKeyDown}
                autoCapitalize="characters"
                autoCorrect="off"
                spellCheck={false}
                placeholder="XXXXXX"
                maxLength={CODE_LENGTH}
                className="h-24 rounded-3xl border-[rgba(100,160,255,0.22)] bg-[rgba(0,20,80,0.72)] px-4 text-center font-mono text-[2.75rem] font-extrabold uppercase leading-none tracking-[0.45em] text-white caret-[hsl(216,75%,72%)] shadow-[inset_0_2px_8px_rgba(0,0,0,0.3)] placeholder:font-mono placeholder:text-[2.75rem] placeholder:font-extrabold placeholder:uppercase placeholder:leading-none placeholder:tracking-[0.45em] placeholder:text-white/12 focus-visible:ring-2 focus-visible:ring-primary-300 md:text-5xl md:placeholder:text-5xl"
              />
              {code && (
                <div className="pointer-events-none absolute -bottom-2 left-1/2 h-4 w-3/4 -translate-x-1/2 bg-[rgba(0,85,216,0.4)] blur-xl" />
              )}
            </div>

            <button
              onClick={() => void handleSubmit()}
              disabled={isSubmitting || !code.trim()}
              className="w-full rounded-2xl bg-[linear-gradient(135deg,#0055d8_0%,#4a8fe0_50%,#669be9_100%)] py-5 text-base font-bold text-white shadow-[0_8px_32px_rgba(0,85,216,0.55),inset_0_2px_0_rgba(255,255,255,0.1)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_14px_44px_rgba(0,85,216,0.7),inset_0_2px_0_rgba(255,255,255,0.1)] active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-60"
            >
              {isSubmitting ? "Шалгаж байна..." : "Бүртгүүлэх"}
            </button>
          </CardContent>
        </Card>

        {recentCheckedIn.length > 0 && (
          <div className="mt-10 w-full max-w-[480px] animate-fade-in [animation-delay:0.5s]">
            <p className="mb-4 text-xs font-bold uppercase tracking-[0.25em] text-[rgba(150,190,255,0.3)]">
              Сүүлд ирсэн
            </p>
            <div className="flex flex-col gap-2">
              {recentCheckedIn.map((attendee, index) => (
                <div
                  key={attendee.code}
                  className={`flex items-center gap-3 rounded-2xl border border-[rgba(100,160,255,0.1)] bg-[rgba(0,40,120,0.3)] px-4 py-3.5 backdrop-blur-[12px] animate-fade-in ${recentAnimationDelayClasses[index] ?? recentAnimationDelayClasses[recentAnimationDelayClasses.length - 1]}`}
                >
                  <div className="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[rgba(0,200,83,0.2)] text-base font-bold text-[hsl(145,100%,45%)]">
                    ✓
                  </div>
                  <div className="min-w-0 flex-1">
                    <p className="truncate text-sm font-semibold text-white">{attendee.name}</p>
                    <p className="font-mono text-xs text-[rgba(150,190,255,0.35)]">{attendee.code}</p>
                  </div>
                  <span className="shrink-0 text-xs text-[rgba(150,190,255,0.25)]">
                    {attendee.checkedInAt
                      ? new Date(attendee.checkedInAt).toLocaleTimeString("mn-MN", {
                          hour: "2-digit",
                          minute: "2-digit",
                        })
                      : ""}
                  </span>
                </div>
              ))}
            </div>
          </div>
        )}

        <p className="mt-14 text-center text-xs text-[rgba(100,140,220,0.2)]">
          Powered by <span className="font-bold text-[rgba(100,140,220,0.35)]">CallPro</span>
        </p>
      </div>
    </div>
  );
}
